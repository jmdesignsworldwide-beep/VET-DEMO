# ─────────────────────────────────────────────────────────────
#  PLANTILLA de variables de entorno para Supabase
#
#  Copia este archivo a ".env.local" y rellena los valores reales.
#  NUNCA subas ".env.local" al repo (ya está ignorado en .gitignore).
# ─────────────────────────────────────────────────────────────

# --- SEGURAS para el navegador (llevan prefijo NEXT_PUBLIC_) ---
# Project URL  ->  Supabase: Project Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# anon / public key  ->  Supabase: Project Settings → API Keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# --- SECRETA, SOLO SERVIDOR (sin NEXT_PUBLIC_, nunca en el navegador) ---
# service_role key  ->  Supabase: Project Settings → API Keys → service_role
# ⚠️ Salta todas las reglas de seguridad (RLS). Jamás la expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY
